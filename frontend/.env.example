# Cinemory frontend — build/runtime configuration (Vite).
# Copy to `.env.local` for local dev. NEVER put secrets here: everything
# prefixed VITE_ is embedded in the client bundle and is public.

# API base URL used by the browser at runtime.
#   • Production (Firebase Hosting): leave EMPTY. The app uses relative paths
#     and Firebase rewrites /health, /occasions, /reels/** to Cloud Run.
#     Single origin, no CORS.
#   • Dev: also leave EMPTY and let the Vite dev-server proxy forward the API
#     routes to VITE_DEV_PROXY_TARGET below (same-origin illusion, no CORS).
#   • Escape hatch: set to an absolute URL to call a backend directly (the
#     backend must then allow that origin).
VITE_API_BASE=

# Where the Vite dev-server proxies API calls in `npm run dev`.
# Defaults to the live Cloud Run service if unset. Point at http://localhost:8000
# to develop against a local `uvicorn cinemory.api:app`.
VITE_DEV_PROXY_TARGET=https://cinemory-595784992266.europe-west1.run.app
