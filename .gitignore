# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.venv/
venv/
.mypy_cache/

# Env / secrets — NEVER commit real credentials
.env
.env.*
!.env.example

# Node / web
web/node_modules/
web/dist/
web/package-lock.json

# React frontend (Vite) — build output covered by dist/ above; keep the
# lockfile committed for reproducible `npm ci` in CI.
frontend/node_modules/
frontend/dist/

# Generated demo output
out/
sample-data/generated/
*.mp4
!sample-data/**/*.md
# Keep the committed demo video + its build work dir stays ignored
!demo/cinemory-demo.mp4
demo/.video-build/

# Firebase Hosting deploy cache
.firebase/

# OS / editor
.DS_Store
.idea/
.vscode/

# PII SAFETY: never commit real personal media or the private cinemory content
# The public repo uses SYNTHETIC demo memories only (see src/cinemory/synthetic.py).
*.jpg
*.jpeg
*.heic
private/
real-memories/
