# ── Cinemory configuration ──────────────────────────────────────────────────
# Copy to `.env` and fill in for the LIVE path. The default (offline) needs NONE
# of these — the app runs fully with fakes so CI and local demos work with zero
# credentials.

# offline (default, fakes, no creds) | live (real Genblaze + Backblaze B2)
CINEMORY_MODE=offline

# fake (default, ffmpeg-free, deterministic) | ffmpeg (real cinematic stitch)
CINEMORY_STITCH=fake

# ── Backblaze B2 (S3-compatible) — required when CINEMORY_MODE=live ──────────
# Two name sets are accepted — you need edit NOTHING here if you already export
# Backblaze's own canonical names (right column). The app resolves them:
#   B2_KEY_ID       or  B2_APPLICATION_KEY_ID
#   B2_APP_KEY      or  B2_APPLICATION_KEY
#   B2_ENDPOINT_URL or  B2_S3_ENDPOINT   (a missing https:// scheme is added)
#   B2_REGION       or  derived from the endpoint host (s3.<region>.backblazeb2.com)
# B2_BUCKET_NAME is the same name either way.
B2_BUCKET_NAME=cinemory-demo
B2_ENDPOINT_URL=https://s3.eu-central-003.backblazeb2.com
# B2 region — used by Genblaze's own S3 storage sink (genblaze_s3.for_backblaze).
# Optional: derived from the endpoint host when unset. Must match the endpoint
# above if set (e.g. eu-central-003, us-west-004).
B2_REGION=eu-central-003
B2_KEY_ID=your-application-key-id
B2_APP_KEY=your-application-key
# Optional key prefix ("folder") prepended to every object key AND index.jsonl
# (alias: B2_PREFIX). Leave unset to write at the bucket root.
# B2_KEY_PREFIX=cinemory/

# ── Genblaze generative provider — required when CINEMORY_MODE=live ─────────
# gmicloud is the provider the live path supports today (config.py gates live
# readiness on GENBLAZE_PROVIDER=gmicloud + GMI_API_KEY). Other Genblaze
# providers (openai | google | runway | luma) are scaffolded/roadmap — setting
# one of them currently degrades to the offline path.
GENBLAZE_PROVIDER=gmicloud
# Key for the live provider (GMI Cloud). The keys below it are placeholders for
# the roadmap providers and are not read by the live path today:
GMI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── API server ──────────────────────────────────────────────────────────────
PORT=8000

# ── OPT-IN live connectors (Google Photos / YouTube / LinkedIn) ──────────────
# All OPTIONAL and consent-gated. Leave blank for the default offline app + CI;
# they are never read by the reference pipeline. Fill only to enable the live,
# opt-in social/import features. See ROADMAP.md for the go-live (app
# verification / API product approval) steps.

# Google OAuth (Photos Picker import + YouTube upload)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_ACCESS_TOKEN=

# LinkedIn share
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
