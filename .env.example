# ── Cinemory configuration ──────────────────────────────────────────────────
# Copy to `.env` and fill in for the LIVE path. The default (offline) needs NONE
# of these — the app runs fully with fakes so CI and local demos work with zero
# credentials.

# offline (default, fakes, no creds) | live (real Genblaze + Backblaze B2)
CINEMORY_MODE=offline

# fake (default, ffmpeg-free, deterministic) | ffmpeg (real cinematic stitch)
CINEMORY_STITCH=fake

# ── Backblaze B2 (S3-compatible) — required when CINEMORY_MODE=live ──────────
B2_BUCKET_NAME=cinemory-demo
B2_ENDPOINT_URL=https://s3.eu-central-003.backblazeb2.com
B2_KEY_ID=your-application-key-id
B2_APP_KEY=your-application-key

# ── Genblaze generative provider — required when CINEMORY_MODE=live ─────────
# One of: gmicloud | openai | google | runway | luma
GENBLAZE_PROVIDER=gmicloud
# Provide the key for your chosen provider:
GMI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── API server ──────────────────────────────────────────────────────────────
PORT=8000
